---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Erik Schwartz — Strategic AI Partner',
  description = 'I help founders and leaders figure out where AI actually moves the needle — then we build it together.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-stone-50 text-stone-800 font-sans">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-stone-50/80 backdrop-blur-lg border-b border-stone-200/60">
      <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-stone-900 font-semibold tracking-tight text-lg hover:text-stone-600 transition-colors">
          Erik Schwartz
        </a>
        <a
          href="/calendar"
          class="text-sm font-medium text-accent hover:text-accent-hover transition-colors"
        >
          Book a conversation
        </a>
      </div>
    </nav>

    <main class="pt-20">
      <slot />
    </main>

    <footer class="border-t border-stone-200 mt-32">
      <div class="max-w-3xl mx-auto px-6 py-12 text-sm text-stone-400">
        <p>&copy; {new Date().getFullYear()} Erik Schwartz</p>
      </div>
    </footer>
  </body>
</html>
