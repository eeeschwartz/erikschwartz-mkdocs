---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book a Conversation — Erik Schwartz">
  <section class="max-w-3xl mx-auto px-6 pt-24 pb-20">
    <h1 class="font-serif text-4xl text-stone-900 tracking-tight">Let's talk</h1>
    <p class="mt-4 text-lg text-stone-500">Pick a time that works for you.</p>

    <div class="mt-12 space-y-4">
      <a
        href="https://cal.com/erikschwartz/15min"
        class="block border border-stone-200 rounded-xl p-6 hover:border-stone-400 transition-colors group"
      >
        <div class="flex items-center justify-between">
          <span class="text-lg font-medium text-stone-900 group-hover:text-accent transition-colors">15 minutes</span>
          <span class="text-sm text-stone-400">&rarr;</span>
        </div>
      </a>

      <a
        href="https://cal.com/erikschwartz/30min"
        class="block border border-stone-200 rounded-xl p-6 hover:border-stone-400 transition-colors group"
      >
        <div class="flex items-center justify-between">
          <span class="text-lg font-medium text-stone-900 group-hover:text-accent transition-colors">30 minutes</span>
          <span class="text-sm text-stone-400">&rarr;</span>
        </div>
      </a>

      <a
        href="https://cal.com/erikschwartz/60min"
        class="block border border-stone-200 rounded-xl p-6 hover:border-stone-400 transition-colors group"
      >
        <div class="flex items-center justify-between">
          <span class="text-lg font-medium text-stone-900 group-hover:text-accent transition-colors">60 minutes</span>
          <span class="text-sm text-stone-400">&rarr;</span>
        </div>
      </a>

      <a
        href="https://cal.com/erikschwartz/60inperson"
        class="block border border-stone-200 rounded-xl p-6 hover:border-stone-400 transition-colors group"
      >
        <div class="flex items-center justify-between">
          <span class="text-lg font-medium text-stone-900 group-hover:text-accent transition-colors">60 minutes &mdash; in person</span>
          <span class="text-sm text-stone-400">&rarr;</span>
        </div>
      </a>
    </div>

    <p class="mt-12 text-stone-400 text-sm">Looking forward to it.</p>
  </section>
</Layout>
